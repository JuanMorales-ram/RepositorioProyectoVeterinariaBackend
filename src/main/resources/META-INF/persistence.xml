<?xml version="1.0" encoding="UTF-8"?>
<persistence version="2.2" xmlns="http://xmlns.jcp.org/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence              http://xmlns.jcp.org/xml/ns/persistence/persistence_2_2.xsd">
  <persistence-unit name="veterinariaPU" transaction-type="RESOURCE_LOCAL">
    <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>
    <non-jta-data-source>Veterinariadatabase</non-jta-data-source>
    <class>veterinaria.mode.entity.Alergia</class>
    <class>veterinaria.mode.entity.HistorialClinico</class>
    <class>veterinaria.mode.entity.Mascota</class>
    <class>veterinaria.mode.entity.MascotaAlergia</class>
    <class>veterinaria.mode.entity.Medicamento</class>
    <class>veterinaria.mode.entity.Propietario</class>
    <class>veterinaria.mode.entity.Tratamiento</class>
    <class>veterinaria.mode.entity.Vacuna</class>
    <class>veterinaria.mode.entity.Vacunacion</class>
    <class>veterinaria.mode.entity.Veterinario</class>
    <exclude-unlisted-classes>false</exclude-unlisted-classes>
    <properties>
      <property name="javax.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
      <property name="javax.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/veterinariadatabase?zeroDateTimeBehavior=CONVERT_TO_NULL"/>
      <property name="javax.persistence.jdbc.user" value="root"/>
      <property name="javax.persistence.jdbc.password" value=""/>
    </properties>
  </persistence-unit>
</persistence>
